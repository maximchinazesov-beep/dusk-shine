                        if val == activeOpt then
                            TweenService:Create(tile.Str, TweenInfo.new(0.2), {Color = CurrentTheme.Accent}):Play()
                            TweenService:Create(tile.Lbl, TweenInfo.new(0.2), {TextColor3 = CurrentTheme.Accent}):Play()
                            if not item.Image:find("rbxthumb") then TweenService:Create(tile.Icon, TweenInfo.new(0.2), {ImageColor3 = CurrentTheme.Accent}):Play() end
                            TweenService:Create(tile.CheckScale, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Scale = 1}):Play()
                        else
