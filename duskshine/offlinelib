local function triggerUpdateSequence()
    local targetGui = pcall(function() return CoreGui.Name end) and CoreGui or LocalPlayer:WaitForChild("PlayerGui")

    if targetGui:FindFirstChild("DuskShineRestartBanner") then
        targetGui.DuskShineRestartBanner:Destroy()
    end

    local gui = Instance.new("ScreenGui")
    gui.Name = "DuskShineRestartBanner"
    gui.Parent = targetGui
    gui.IgnoreGuiInset = true
    gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling

    -- Настройки текста
    local textSegment = "SERVER RESTARTING SOON!   "
    local fontSize = 24
    local font = Enum.Font.FredokaOne 

    local segmentWidth = TextService:GetTextSize(textSegment, fontSize, font, Vector2.new(10000, 30)).X
    local repeatedText = string.rep(textSegment, 100)

    local function createBanner(isTop)
        local frame = Instance.new("Frame")
        frame.Size = UDim2.new(1, 0, 0, 32)
        frame.Position = isTop and UDim2.new(0, 0, 0, 0) or UDim2.new(0, 0, 1, -32)
        frame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
        frame.BackgroundTransparency = 0.4
        frame.BorderSizePixel = 0
        frame.ClipsDescendants = true
        frame.Parent = gui

        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(0, segmentWidth * 100, 1, 0)
        label.Position = UDim2.new(0, 0, 0, 0)
        label.BackgroundTransparency = 1
        label.Text = repeatedText
        label.Font = font
        label.TextSize = fontSize
        label.TextXAlignment = Enum.TextXAlignment.Left
        label.Parent = frame

        local stroke = Instance.new("UIStroke")
        stroke.Thickness = 2.5
        stroke.Color = Color3.fromRGB(0, 0, 0)
        stroke.Parent = label

        local scrollSpeed = 95
        local rgbSpeed = 6

        RunService.RenderStepped:Connect(function()
            local hue = (tick() % rgbSpeed) / rgbSpeed
            label.TextColor3 = Color3.fromHSV(hue, 1, 1)
            local offset = (tick() * scrollSpeed) % segmentWidth
            label.Position = UDim2.new(0, -offset, 0, 0)
        end)
    end

    -- Спавним верхнюю и нижнюю плашки
    createBanner(true)
    createBanner(false)

    -- Ждем 60 секунд (плашки в это время крутятся), затем телепортируем
    task.wait(60)
    serverHopToPublic()
end

-- 3. Функция фонового опроса твоего сайта
local function startPolling()
    task.spawn(function()
        while task.wait(CHECK_INTERVAL) do
            -- Делаем запрос к сайту
            local success, response = pcall(function()
                return game:HttpGet(CHECK_URL)
            end)

            if success and response then
                -- Если сайт вернул нужный триггер — запускаем процесс обновления
                if string.find(response, TRIGGER_WORD) then
                    triggerUpdateSequence()
                    break -- Выходим из цикла опроса
                end
            end
        end
    end)
end

