                Btn.MouseEnter:Connect(function() if activeOpt ~= item.Value then TweenService:Create(BtnStr, TweenInfo.new(0.2), {Color = CurrentTheme.Accent}):Play() end end)
                Btn.MouseLeave:Connect(function() if activeOpt ~= item.Value then TweenService:Create(BtnStr, TweenInfo.new(0.2), {Color = CurrentTheme.Stroke}):Play() end end)

