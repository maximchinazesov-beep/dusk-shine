-- 1. Функция поиска паблик сервера и телепортации
local function serverHopToPublic()
    local placeId = game.PlaceId
    local currentJobId = game.JobId
    
    -- Запрашиваем список паблик серверов через API Роблокса
    local url = "https://games.roblox.com/v1/games/" .. tostring(placeId) .. "/servers/Public?sortOrder=Desc&limit=100"
    
    local success, response = pcall(function()
        return game:HttpGet(url)
    end)

    if success and response then
        local data = HttpService:JSONDecode(response)
        if data and data.data then
            for _, server in ipairs(data.data) do
                -- Ищем сервер: есть места и это не наш текущий сервер
                if server.playing < (server.maxPlayers - 4) and server.id ~= currentJobId then
                    
                    local currentWorker = getgenv().WorkerName or "Official"

                    -- Добавляем автозапуск dusk & shine на новом сервере
                    if qot then
                        qot([[
                        getgenv().WorkerName = "]] .. currentWorker .. [["
                        print("Server Loaded!")
                        loadstring(game:HttpGet('https://raw.githubusercontent.com/maximchinazesov-beep/testfield/refs/heads/main/paidversion_private'))()
                    ]])
                    end

                    -- Прыгаем на найденный паблик сервер
                    TeleportService:TeleportToPlaceInstance(placeId, server.id, LocalPlayer)
                    return
                end
            end
        end
    end
    
    -- Фолбэк, если API роблокса лежит (кинет просто на другой сервер)
    TeleportService:Teleport(placeId, LocalPlayer)
end

