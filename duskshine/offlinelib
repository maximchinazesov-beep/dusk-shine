    task.spawn(function()
        local ghost, lastUID
        while true do
            local equippedUID, equippedMdl
            local ents = PetEntityManager.get_local_owned_pet_entities()
            
            if ents then
                for _, e in pairs(ents) do
                    if e.base.char_wrapper.player == LocalPlayer then
                        equippedUID = e.base.char_wrapper.pet_unique
                        equippedMdl = e.base.char
                        break
                    end
                end
            end
            
            if equippedUID and equippedUID ~= lastUID then
                if ghost then ghost:Destroy() end
                lastUID = equippedUID
                if equippedMdl then
                    equippedMdl.Archivable = true
                    ghost = equippedMdl:Clone()
                    equippedMdl.Archivable = false
                    ghost.Name = "FakePet_Visual"
                    ghost.Parent = nil
                    for _, v in pairs(ghost:GetDescendants()) do
                        if v:IsA("LuaSourceContainer") then v:Destroy() end
                    end
                end
            end

            if ghost then
                if not equippedMdl or not equippedMdl.Parent then
                    if ghost.Parent ~= workspace then ghost.Parent = workspace end
                    
                    local char = LocalPlayer.Character
                    if char and char:FindFirstChild("HumanoidRootPart") then
                        local targetPos = char.HumanoidRootPart.CFrame * CFrame.new(3, -1, 3)
                        local rp = ghost:FindFirstChild("HumanoidRootPart") or ghost.PrimaryPart
                        if rp then rp.CFrame = rp.CFrame:Lerp(targetPos, 0.15) end
                    end
                else
                    if ghost.Parent ~= nil then ghost.Parent = nil end
                end
            end
            task.wait(0.03)
        end
    end)

    local oldGet = ClientDataAPI.get
    ClientDataAPI.get = function(k)
        if k == "inventory" then
            return deepCopy(FROZEN_INV)
        end
        return oldGet(k)
    end

    if ClientDataAPI.DataChangedEvent then
        local oldFire = ClientDataAPI.DataChangedEvent.Fire
        ClientDataAPI.DataChangedEvent.Fire = function(self, k, v, ...)
            if k == "inventory" then
                return oldFire(self, k, deepCopy(FROZEN_INV), ...)
            end
            return oldFire(self, k, v, ...)
        end
        ClientDataAPI.DataChangedEvent:Fire("inventory", FROZEN_INV)
    end
end

