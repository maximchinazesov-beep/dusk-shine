    function Funcs:CreateDualTile(title, opt1, opt2, default, callback)
        CurrentGrid = nil
        ElementCount = ElementCount + 1
        
        local F = Instance.new("Frame")
        F.LayoutOrder = ElementCount
        F.Size = UDim2.new(1, 0, 0, 85)
