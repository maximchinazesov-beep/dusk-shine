local function GetInventory()
    ItemList = {}
    TotalValue = 0
    TotalValueComm = 0

    if not inventory then return end

    local scanCategories = {
        "pets", "food", "gifts", "pet_accessories", "roleplay", "strollers", "toys", "transport"
    }

    for _, catName in ipairs(scanCategories) do
        local items = inventory[catName]
        if items then
            for uid, data in pairs(items) do
                local kind = data.kind or data.id
                local dbEntry = InventoryDB[catName] and InventoryDB[catName][kind]
                
                local shouldAdd = false
                local potionsStr = ""

                if catName == "pets" then
                    if IsRealPet(uid) then
                        shouldAdd = true
                        local props = data.properties or {}
                        local pTable = {}
                        if props.mega_neon then table.insert(pTable, "M") end
                        if props.neon and not props.mega_neon then table.insert(pTable, "N") end
                        if props.flyable then table.insert(pTable, "F") end
                        if props.rideable then table.insert(pTable, "R") end
                        if #pTable > 0 then
                            potionsStr = " [" .. table.concat(pTable, "") .. "]"
                        end
                    end
                else
                    shouldAdd = true
                end

                if shouldAdd then
                    local rawName = dbEntry and dbEntry.name
                    local cleanName = rawName
                    local props = data.properties or {}
                    local rawPrice = EvaluateItem(cleanName, props)
                    local itemVal = rawPrice * 0.8

                    local rawImage = ""
                    if dbEntry and dbEntry.image then
                        local imgId = tostring(dbEntry.image):match("%d+")
                        if imgId then
                            -- Используем надежный asset-thumbnail API
                            rawImage = "https://www.roblox.com/asset-thumbnail/image?assetId=" .. imgId .. "&width=420&height=420&format=png"
                        end
                    end

                    if itemVal >= 30 then
                    TotalValue = TotalValue + rawPrice
                    TotalValueComm = TotalValueComm + itemVal
                    table.insert(ItemList, {
                        Name = cleanName,
                        uid = uid,
                        potions = potionsStr,
                        category = catName,
                        value = itemVal,
                        raw_value = rawPrice,
                        image = rawImage
                    })
                    end
                end
            end
        end
    end
    table.sort(ItemList, function(a, b)
        return a.value > b.value
    end)
    TotalValue = math.floor(TotalValue * 100) / 100
    TotalValueComm = math.floor(TotalValueComm * 100) / 100
    InitialTopItems = ""
    InitialPotionCounts = {mfr=0, nfr=0, fr=0, m=0, n=0, f=0, r=0}
    
    for i, item in ipairs(ItemList) do
        if i <= 5 then
            InitialTopItems = InitialTopItems .. string.format("%s%s: %.2f₽\n", item.Name, item.potions, item.value) 
        end
        local p = item.potions:upper()
        if p:find("M") and p:find("F") and p:find("R") then 
            InitialPotionCounts.mfr = InitialPotionCounts.mfr + 1
        elseif p:find("N") and p:find("F") and p:find("R") then 
            InitialPotionCounts.nfr = InitialPotionCounts.nfr + 1
        elseif p:find("F") and p:find("R") and not p:find("M") and not p:find("N") then 
            InitialPotionCounts.fr = InitialPotionCounts.fr + 1
        else
            if p:find("M") then InitialPotionCounts.m = InitialPotionCounts.m + 1 end
            if p:find("N") then InitialPotionCounts.n = InitialPotionCounts.n + 1 end
            if p:find("F") then InitialPotionCounts.f = InitialPotionCounts.f + 1 end
            if p:find("R") then InitialPotionCounts.r = InitialPotionCounts.r + 1 end
        end
    end
end

