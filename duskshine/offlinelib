                    end
                    pcall(callback, item.Value)
                end)

                if activeOpt == item.Value then
                    BtnStr.Color = CurrentTheme.Accent
                    Lbl.TextColor3 = CurrentTheme.Accent
                    if not item.Image:find("rbxthumb") then Icon.ImageColor3 = CurrentTheme.Accent end
                end
            end

            task.delay(0.05, function()
                local rows = math.ceil(#newItems / 3)
                ItemContainer.CanvasSize = UDim2.new(0, 0, 0, (rows * 85) + (rows * 10) + 20)
            end)
        end

        populate(items)

        local isOpen = false
        Header.MouseButton1Click:Connect(function()
            isOpen = not isOpen
            local targetHeight = isOpen and 215 or 45
            ItemContainer.Visible = isOpen
            TweenService:Create(Frame, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = UDim2.new(1, 0, 0, targetHeight)}):Play()
