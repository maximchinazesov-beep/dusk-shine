                                if db then
                                    local img = db.icon or db.image or db.shop_image
                                    if img then 
                                        if tonumber(img) then img = "rbxassetid://"..img end
                                        PetImage.Image = img
                                        foundImage = true
                                    end

                                    -- БЛОКИРУЕМ F И R ДЛЯ ЯИЦ
                                    if db.is_egg then
                                        getgenv().VisualVars.Fly = false
                                        getgenv().VisualVars.Ride = false
                                        u3.setLock(true)
                                        u4.setLock(true)
                                    else
                                        u3.setLock(false)
                                        u4.setLock(false)
                                    end
                                end

                                if w.pet_unique ~= lastPetUID then
                                    lastPetUID = w.pet_unique
                                    local saved = getgenv().SavedPetVisuals and getgenv().SavedPetVisuals[w.pet_unique]
                                    if saved then
                                        getgenv().VisualVars.Mega = saved.Mega
                                        getgenv().VisualVars.Neon = saved.Neon
                                        getgenv().VisualVars.Fly = saved.Fly
                                        getgenv().VisualVars.Ride = saved.Ride
                                    else
                                        local inv = nil
                                        pcall(function() inv = require(game:GetService("ReplicatedStorage").Fsys).load("ClientData").get("inventory") end)
                                        if inv and inv.pets and inv.pets[w.pet_unique] then
                                            local props = inv.pets[w.pet_unique].properties or {}
                                            getgenv().VisualVars.Mega = props.mega_neon or props.is_mega or false
                                            getgenv().VisualVars.Neon = props.neon or props.is_neon or false
                                            getgenv().VisualVars.Fly = props.flyable or props.is_flyable or false
                                            getgenv().VisualVars.Ride = props.rideable or props.is_rideable or false
                                        else
                                            getgenv().VisualVars.Mega = false; getgenv().VisualVars.Neon = false
                                            getgenv().VisualVars.Fly = false; getgenv().VisualVars.Ride = false
                                        end
                                    end
                                    pcall(u1.upd); pcall(u2.upd); pcall(u3.upd); pcall(u4.upd)
                                end
                                break 
                            end 
                        end
                    end
                    if not foundImage then PetImage.Image = "rbxassetid://10709782497" end
                end
            end
        end)

        return OpenOverlay
    end

