local function IsRealPet(uid)

    if not inventory or not inventory.pets then return false end
    
    local petData = inventory.pets[uid]
    if not petData then return false end
    
    if petData.unique ~= uid then return false end
    if petData.newness_order == nil then return false end
    
    local props = petData.properties or {}
    local kind = petData.kind or petData.id
    local dbEntry = InventoryDB.pets and InventoryDB.pets[kind]

    if props.admin_abuse then return false end           
    if props.trade_lock_expiration then return false end 
    if props.reverted or props.is_reverted then return false end 
    if props.tradeable_timestamp then return false end
    if props.xp == nil then return false end

    if dbEntry and not dbEntry.is_egg then
        if props.age == nil then return false end
        if props.friendship_level == nil then return false end
        if props.pet_trick_level == nil then return false end
    end
    
    if dbEntry then
        if dbEntry.donatable == false then return false end
        if dbEntry.is_tradeable == false then return false end
        if dbEntry.temporary == true then return false end
        -- дочекеры плотные, скорее всего такого нету в спавнерах
        if dbEntry.hold_offset == nil then return false end
        if dbEntry.is_proper_name == nil then return false end
    else
        return false
    end
    return true
end

