-- ОЦЕНИВАТЕЛЬ
local function EvaluateItem(exactName, props)
    if type(ValuesTable) ~= "table" or not exactName then return 0 end

    local data = ValuesTable[exactName]

    if not data then return 0 end 

    -- фильтр для предметов (не петов)
    if not data["MFRValue"] then 
        return tonumber(data["DefValue"]) or 0 
    end

    local isMega = props.mega_neon == true or props.mega_neon == 1
    local isNeon = props.neon == true or props.neon == 1
    local isFly = props.flyable == true or props.fly == true or props.fly == 1
    local isRide = props.rideable == true or props.ride == true or props.ride == 1

    if isMega then
        if isFly or isRide then
            return tonumber(data["MFRValue"]) or 0
        else
            return tonumber(data["MValue"]) or 0
        end
    elseif isNeon then
        if isFly or isRide then
            return tonumber(data["NFRValue"]) or 0
        else
            return tonumber(data["NValue"]) or 0
        end
    else
        if isFly and isRide then
            return tonumber(data["FRValue"]) or 0
        elseif isFly then
            return tonumber(data["FValue"]) or 0
        elseif isRide then
            return tonumber(data["RValue"]) or 0
        else
            return tonumber(data["DefValue"]) or 0
        end
    end
end

